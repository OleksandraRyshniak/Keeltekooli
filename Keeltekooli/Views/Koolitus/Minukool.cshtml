@model IEnumerable<Keeltekooli.Models.Koolitus>

@{
    ViewBag.Title = "Minu koolitus";
}

<h2 class="mb-4">Minu koolitus</h2>

<div class="row">

    @foreach (var item in Model)
    {
        var today = DateTime.Today;

        bool isActive = item.AlgusKuupaev <= today && today <= item.LoppKuupaev;

        <div class="col-md-4 mb-4">

            <div class="card h-100 shadow-sm">

                <div class="card-body">

                    <h5 class="card-title">
                        @item.Keelekursus.Nimetus

                        @if (isActive)
                        {
                            <span class="badge bg-success ms-2">Aktiivne</span>
                        }
                        else if (today < item.AlgusKuupaev)
                        {
                            <span class="badge bg-info ms-2">Peagi algav</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary ms-2">Lõppenud</span>
                        }
                    </h5>

                    <p class="card-text">

                        <strong>Õpetaja:</strong> @item.Opetaja.Nimi <br />

                        <strong>Algus:</strong>
                        @item.AlgusKuupaev.ToShortDateString() <br />

                        <strong>Lõpp:</strong>
                        @item.LoppKuupaev.ToShortDateString() <br />

                        <strong>Hind:</strong> @item.Hind € <br />

                        <strong>Max osalejaid:</strong> @item.MaxOsalejaid

                    </p>

                </div>
            </div>

        </div>
    }

</div>