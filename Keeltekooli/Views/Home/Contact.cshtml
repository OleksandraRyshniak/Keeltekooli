@{
    ViewBag.Title = "Kontakt";
}

<main class="container py-5" aria-labelledby="title">

    <div class="text-center mb-5">
        <h1 id="title" class="fw-bold">📬 Kontakt</h1>
        <p class="text-muted">Võta ühendust meie kooliga – LanguageBridge</p>
    </div>

    <div class="row g-4">

        <!-- School Info -->
        <div class="col-md-4">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body text-center">
                    <h5 class="card-title">🏫 LanguageBridge</h5>
                    <p class="card-text text-muted">
                        Keelekool, mis aitab sul avada uksi rahvusvahelisse maailma.
                    </p>

                    <address class="mt-3">
                        <strong>Aadress</strong><br />
                        One Microsoft Way<br />
                        Redmond, WA 98052-6399<br />
                    </address>
                </div>
            </div>
        </div>

        <!-- Support -->
        <div class="col-md-4">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body text-center">
                    <h5>📧 Tugi</h5>

                    <p class="mt-3">
                        <strong>Support:</strong><br />
                        <a class="text-decoration-none" href="mailto:Support@languagebridge.com">
                            Support@languagebridge.com
                        </a>
                    </p>

                    <p>
                        <strong>Turundus:</strong><br />
                        <a class="text-decoration-none" href="mailto:Marketing@languagebridge.com">
                            Marketing@languagebridge.com
                        </a>
                    </p>
                </div>
            </div>
        </div>

        <!-- Phone -->
        <div class="col-md-4">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body text-center d-flex flex-column justify-content-center">
                    <h5>📞 Kontakt</h5>

                    <p class="mt-3 mb-1">Telefon</p>
                    <h4>425.555.0100</h4>

                    <small class="opacity-75">Tööpäeviti 09:00 – 18:00</small>
                </div>
            </div>
        </div>

    </div>
</main>
