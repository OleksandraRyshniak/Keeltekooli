@model Keeltekooli.Models.EmailViewModel

@{
    ViewBag.Title = "Saada e-mail kõigile";
}

<h2>@ViewBag.Title</h2>

@if (ViewBag.Message != null)
{
    <div class="alert alert-success">
        @ViewBag.Message
    </div>
}

@using (Html.BeginForm("SendEmailAll", "SendEmail", FormMethod.Post))
{
    @Html.AntiForgeryToken()

    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

    <div class="form-group">
        @Html.LabelFor(m => m.Subject, "Teema")
        @Html.TextBoxFor(m => m.Subject, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Subject, "", new { @class = "text-danger" })
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.Body, "Sisu")
        @Html.TextAreaFor(m => m.Body, new { @class = "form-control", rows = 6 })
        @Html.ValidationMessageFor(m => m.Body, "", new { @class = "text-danger" })
    </div>

    <br />

    <button type="submit" class="btn btn-danger">
        Saada kõigile
    </button>
}