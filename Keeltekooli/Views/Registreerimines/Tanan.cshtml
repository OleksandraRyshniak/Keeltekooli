@model Keeltekooli.Models.Registreerimine

@{
    ViewBag.Title = "Tänan registreerumise eest!";
}

<h2>Tänan registreerumise eest!</h2>

<p>Olete registreeritud kursusele: <strong>@ViewBag.Kursus</strong></p>
<p>Keelekursus: <strong>@ViewBag.Keelekursus</strong></p>
<p>Õpetaja: <strong>@ViewBag.Opetaja</strong></p>
<p>Teie registreerimise staatus: <strong>@ViewBag.Staatus</strong></p>

<p>Ootame teid kursusel! Kontrollige oma e-posti, et näha kinnitust.</p>